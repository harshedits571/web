{
    "rules": {
        "users": {
            ".indexOn": ["email"],
            // PERMISSION FOR ADMIN TO READ ALL USERS, or ALLOW EXACT EMAIL QUERY FOR SUB-ADMIN LOGIN
            ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('isAdmin').val() === true || (query.orderByChild == 'email' && query.equalTo != null)",
            "$uid": {
                // Individual user access (User themselves OR Admin)
                ".read": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('isAdmin').val() === true",
                ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('isAdmin').val() === true"
            }
        },
        // User Messages (Fixes Dashboard Stats)
        "userMessages": {
            ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'sub-admin' || root.child('users').child(auth.uid).child('isAdmin').val() === true || root.child('users').child(auth.uid).child('allowedSections').val() != null",
            ".write": "auth != null"
        },
        // Broken Link Reports
        "brokenLinkReports": {
            ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'sub-admin' || root.child('users').child(auth.uid).child('isAdmin').val() === true || root.child('users').child(auth.uid).child('allowedSections').val() != null",
